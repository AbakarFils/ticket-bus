<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp"
    android:background="@color/background">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🚌 TicketBus — Contrôle" android:textSize="20sp" android:textStyle="bold"
        android:textColor="@color/primary" android:layout_marginBottom="8dp" />
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="● En ligne" android:textSize="14sp" android:layout_marginBottom="24dp" />
    <Button android:id="@+id/btnScan" android:layout_width="match_parent" android:layout_height="64dp"
        android:text="📷 Scanner un QR code" android:textSize="16sp"
        android:backgroundTint="@color/secondary" android:textColor="@color/white"
        android:layout_marginBottom="12dp" />
    <Button android:id="@+id/btnSync" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="↻ Synchroniser" android:backgroundTint="@color/primary"
        android:textColor="@color/white" android:layout_marginBottom="8dp" />
    <Button android:id="@+id/btnSyncStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="📊 État de la synchronisation"
        android:backgroundTint="#95a5a6" android:textColor="@color/white" />
</LinearLayout>
